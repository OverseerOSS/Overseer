generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(cuid())
  username String @unique
  password String
}

model ServiceMonitor {
  id          String @id @default(cuid())
  name        String
  description String?
  type        String   @default("http")
  url         String?
  method      String?  @default("GET")
  config      String   @default("{}") // JSON string for specific settings (headers, body etc)
  interval    Int      @default(60) // Polling interval in seconds
  active      Boolean  @default(true)
  lastStatus  String   @default("unknown")
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
  order       Int      @default(0) // Display order
  metrics     Metric[]
  statusPages StatusPage[]
  notificationChannels NotificationChannel[]
  sshKey      SshKey?
}

model SshKey {
  id              String @id @default(cuid())
  monitorId       String @unique
  monitor         ServiceMonitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  publicKey       String // OpenSSH format public key
  encryptedPrivateKey String // Encrypted PEM format private key
  fingerprint     String // SSH key fingerprint for display
  createdAt       DateTime @default(now())
}

model Metric {
  id        String   @id @default(cuid())
  monitorId String
  monitor   ServiceMonitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  timestamp DateTime @default(now())
  data      String   // JSON string storing { cpu, ram, ... }

  @@index([monitorId, timestamp])
}

model NotificationChannel {
  id        String   @id @default(cuid())
  name      String
  type      String   @default("discord")
  config    String   @default("{}") // JSON: { webhookUrl: string }
  active    Boolean  @default(true)
  monitors  ServiceMonitor[]
  createdAt DateTime @default(now())
}

model StatusPage {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?
  showMetrics Boolean  @default(false)
  showCpu     Boolean  @default(true)
  showRam     Boolean  @default(true)
  showNetwork Boolean  @default(true)
  showBanner  Boolean  @default(true)
  showHistory Boolean  @default(true)
  showRecentHistory Boolean @default(true)
  config      Json?    // Advanced config: { monitorId: { includedServices: string[] } }
  monitors    ServiceMonitor[]
}

model SystemSettings {
  id    String @id @default(cuid())
  key   String @unique // e.g., "orgName"
  value String
}
