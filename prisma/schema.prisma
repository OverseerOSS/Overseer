generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(cuid())
  username String @unique
  password String
}

model InstalledExtension {
  id          String @id @default(cuid())
  extensionId String @unique
  config      String? // Global configuration (JSON)
  installedAt DateTime @default(now())
}

model ServiceMonitor {
  id          String @id @default(cuid())
  name        String
  extensionId String 
  config      String // JSON string
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
  order       Int      @default(0) // Display order
  metrics     Metric[]
  statusPages StatusPage[]
}

model StatusPage {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?
  monitors    ServiceMonitor[]
}

model Metric {
  id        String   @id @default(cuid())
  monitorId String
  monitor   ServiceMonitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  timestamp DateTime @default(now())
  data      String   // JSON string storing { cpu, ram, ... }

  @@index([monitorId, timestamp])
}
