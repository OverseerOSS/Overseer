# Database
DATABASE_URL="postgresql://user:password@localhost:5432/overseer"

# Session Secret (must be at least 32 characters long)
# Generate with: openssl rand -base64 32
SESSION_SECRET="your-very-long-random-secret-at-least-32-characters"

# Allowed origins for Server Actions (comma-separated)
ALLOWED_ORIGINS="localhost:3000,localhost:3001,*.github.dev"

# Environment
NODE_ENV="development"
